# RiftHub local environment template.
# Copy this file to `.env` and edit the values for your machine.
# The application loads `.env` at runtime. It does not load `.env.example`.

# App
RIFTHUB_ENV=development
RIFTHUB_LOG_LEVEL=INFO
RIFTHUB_API_HOST=127.0.0.1
RIFTHUB_API_PORT=8000
RIFTHUB_SQL_ECHO=false

# Postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=rifthub
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-local-password

# SQLAlchemy / Alembic
RIFTHUB_DATABASE_URL=postgresql+asyncpg://postgres:change-me-local-password@127.0.0.1:5432/rifthub
RIFTHUB_MIGRATION_DATABASE_URL=postgresql+asyncpg://postgres:change-me-local-password@127.0.0.1:5432/rifthub
